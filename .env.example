# Go High Level inbound webhook URL from your lead-capture workflow.
# Netlify: Site settings → Environment variables → add GHL_WEBHOOK_URL
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# Intake questionnaire → Command Center (submit-intake.js)
# Use the same Supabase project as the Revenue Command Center.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Your Supabase auth user UUID (Dashboard → Authentication → Users)
INTAKE_OWNER_USER_ID=your-user-uuid

# Email notification on new intake (Resend — https://resend.com)
RESEND_API_KEY=re_...
NOTIFY_EMAIL=you@jollymammoth.co
# Optional — verify your domain in Resend for production; default uses Resend sandbox sender
# INTAKE_FROM_EMAIL=Jolly Mammoth <intake@jollymammoth.co>

# Voice transcription for intake questionnaire (transcribe-intake.js — OpenAI Whisper)
OPENAI_API_KEY=sk-...
